# 静态资源缓存配置
# 针对不同类型的静态资源设置不同的缓存策略

# ============ 全局缓存配置 ============
default:
  etag: true
  last_modified: true
  vary: "Accept-Encoding"

# ============ 文件类型缓存策略 ============
file_types:
  # JavaScript 文件
  javascript:
    extensions: [".js", ".mjs", ".jsx"]
    cache_control:
      public: true
      max_age: 604800  # 7天
      immutable: true  # 使用hash的文件名，永不改变
    cdn:
      edge_ttl: 2592000  # 30天
      stale_while_revalidate: 86400  # 1天
    compression:
      - brotli
      - gzip
    headers:
      - "Content-Type: application/javascript; charset=utf-8"
      - "X-Content-Type-Options: nosniff"
      
  # CSS 文件
  css:
    extensions: [".css", ".scss", ".sass", ".less"]
    cache_control:
      public: true
      max_age: 604800  # 7天
      immutable: true
    cdn:
      edge_ttl: 2592000  # 30天
      stale_while_revalidate: 86400
    compression:
      - brotli
      - gzip
    headers:
      - "Content-Type: text/css; charset=utf-8"
      
  # 图片文件
  images:
    extensions: [".png", ".jpg", ".jpeg", ".gif", ".svg", ".webp", ".ico", ".avif"]
    cache_control:
      public: true
      max_age: 2592000  # 30天
      immutable: true
    cdn:
      edge_ttl: 7776000  # 90天
      image_optimization: true  # 启用图片优化
    compression:
      - brotli  # SVG可用
    headers:
      - "Cache-Control: public, max-age=2592000, immutable"
      
  # 字体文件
  fonts:
    extensions: [".woff", ".woff2", ".ttf", ".otf", ".eot"]
    cache_control:
      public: true
      max_age: 31536000  # 1年
      immutable: true
    cdn:
      edge_ttl: 31536000  # 1年
    compression:
      - brotli  # WOFF2已压缩，但brotli可以压缩其他字体
    headers:
      - "Access-Control-Allow-Origin: *"
      - "Cache-Control: public, max-age=31536000, immutable"
      
  # JSON 数据文件
  json:
    extensions: [".json", ".geojson"]
    cache_control:
      public: true
      max_age: 3600  # 1小时
    cdn:
      edge_ttl: 3600
      stale_while_revalidate: 300  # 5分钟
    compression:
      - brotli
      - gzip
    headers:
      - "Content-Type: application/json; charset=utf-8"
      
  # HTML 文件
  html:
    extensions: [".html", ".htm"]
    cache_control:
      public: true
      max_age: 0  # 不缓存，或非常短
      must_revalidate: true
    cdn:
      edge_ttl: 300  # 5分钟
      stale_while_revalidate: 60
    compression:
      - brotli
      - gzip
    headers:
      - "Content-Type: text/html; charset=utf-8"
      - "X-Frame-Options: DENY"
      - "X-XSS-Protection: 1; mode=block"
      
  # Markdown 文档
  markdown:
    extensions: [".md", ".markdown"]
    cache_control:
      public: true
      max_age: 3600  # 1小时
    cdn:
      edge_ttl: 3600
    compression:
      - brotli
      - gzip
    headers:
      - "Content-Type: text/markdown; charset=utf-8"
      
  # PDF 文档
  pdf:
    extensions: [".pdf"]
    cache_control:
      public: true
      max_age: 86400  # 1天
    cdn:
      edge_ttl: 604800  # 7天
    compression: []  # PDF已压缩
    headers:
      - "Content-Type: application/pdf"
      
  # Lean/Mathlib 文件
  lean:
    extensions: [".lean", ".olean", ".ilean"]
    cache_control:
      public: true
      max_age: 86400  # 1天
    cdn:
      edge_ttl: 604800  # 7天
    compression:
      - brotli
      - gzip
    headers:
      - "Content-Type: text/x-lean"
      
  # 视频文件
  video:
    extensions: [".mp4", ".webm", ".ogv"]
    cache_control:
      public: true
      max_age: 2592000  # 30天
    cdn:
      edge_ttl: 2592000
      streaming_optimization: true
    compression: []  # 视频已压缩
    headers:
      - "Accept-Ranges: bytes"
      
  # 音频文件
  audio:
    extensions: [".mp3", ".wav", ".ogg", ".m4a"]
    cache_control:
      public: true
      max_age: 2592000  # 30天
    cdn:
      edge_ttl: 2592000
    compression: []
    headers:
      - "Accept-Ranges: bytes"

# ============ 目录特定配置 ============
directories:
  # 构建产物（哈希文件名）
  build:
    path: "/build/"
    cache_control:
      public: true
      max_age: 31536000  # 1年
      immutable: true
    cdn:
      edge_ttl: 31536000
      
  # 版本化资源
  versioned:
    path: "/assets/"
    cache_control:
      public: true
      max_age: 31536000
      immutable: true
    cdn:
      edge_ttl: 31536000
      
  # 数学公式缓存
  formula_cache:
    path: "/cache/formulas/"
    cache_control:
      public: true
      max_age: 604800  # 7天
    cdn:
      edge_ttl: 2592000  # 30天
      
  # 知识图谱导出
  kg_exports:
    path: "/exports/"
    cache_control:
      public: true
      max_age: 3600  # 1小时
    cdn:
      edge_ttl: 3600

# ============ 缓存键策略 ============
cache_key:
  include:
    - scheme
    - host
    - uri
    - query_string: ["v", "version", "lang"]  # 只包含版本和语言参数
  exclude:
    - query_string: ["utm_source", "utm_medium", "utm_campaign", "fbclid", "gclid"]
  vary_by:
    - "Accept-Encoding"
    - "Accept-Language"

# ============ 缓存预热配置 ============
warmup:
  enabled: true
  schedule: "0 2 * * *"  # 每天凌晨2点
  paths:
    - "/static/js/main.*.js"
    - "/static/css/main.*.css"
    - "/assets/fonts/"
  concurrency: 10
  batch_size: 100
