# =============================================================================
# FormalMath API - 生产数据库 Docker Compose 配置
# 包含 PostgreSQL + Redis Cluster
# =============================================================================

version: '3.8'

services:
  # PostgreSQL 主节点
  postgres-primary:
    image: postgres:16-alpine
    container_name: formalmath-postgres-primary
    hostname: postgres-primary
    environment:
      POSTGRES_USER: formalmath
      POSTGRES_PASSWORD: ${DB_PASSWORD:-formalmath_password}
      POSTGRES_DB: formalmath
      PGDATA: /var/lib/postgresql/data/pgdata
    volumes:
      - postgres_primary_data:/var/lib/postgresql/data
      - ./config/postgresql.conf:/etc/postgresql/postgresql.conf:ro
      - ./scripts/backup:/backup:ro
    ports:
      - "5432:5432"
    command: >
      postgres
      -c config_file=/etc/postgresql/postgresql.conf
      -c max_connections=500
      -c shared_buffers=2GB
      -c effective_cache_size=6GB
      -c work_mem=16MB
    networks:
      - formalmath-db
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U formalmath"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  # PostgreSQL 从节点 1
  postgres-replica-1:
    image: postgres:16-alpine
    container_name: formalmath-postgres-replica-1
    hostname: postgres-replica-1
    environment:
      POSTGRES_USER: formalmath
      POSTGRES_PASSWORD: ${DB_PASSWORD:-formalmath_password}
      PGDATA: /var/lib/postgresql/data/pgdata
      PRIMARY_HOST: postgres-primary
      PRIMARY_PORT: 5432
      REPLICA_USER: replicator
      REPLICA_PASSWORD: ${REPLICA_PASSWORD:-replicator_password}
    volumes:
      - postgres_replica1_data:/var/lib/postgresql/data
    ports:
      - "5433:5432"
    networks:
      - formalmath-db
    depends_on:
      - postgres-primary
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U formalmath"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    command: >
      bash -c "
        if [ ! -s $$PGDATA/PG_VERSION ]; then
          echo 'Initializing replica from primary...';
          PGPASSWORD=$$REPLICA_PASSWORD pg_basebackup -h $$PRIMARY_HOST -p $$PRIMARY_PORT -U $$REPLICA_USER -D $$PGDATA -Fp -Xs -P -R;
        fi;
        postgres
      "

  # PostgreSQL 从节点 2
  postgres-replica-2:
    image: postgres:16-alpine
    container_name: formalmath-postgres-replica-2
    hostname: postgres-replica-2
    environment:
      POSTGRES_USER: formalmath
      POSTGRES_PASSWORD: ${DB_PASSWORD:-formalmath_password}
      PGDATA: /var/lib/postgresql/data/pgdata
      PRIMARY_HOST: postgres-primary
      PRIMARY_PORT: 5432
      REPLICA_USER: replicator
      REPLICA_PASSWORD: ${REPLICA_PASSWORD:-replicator_password}
    volumes:
      - postgres_replica2_data:/var/lib/postgresql/data
    ports:
      - "5434:5432"
    networks:
      - formalmath-db
    depends_on:
      - postgres-primary
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U formalmath"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    command: >
      bash -c "
        if [ ! -s $$PGDATA/PG_VERSION ]; then
          echo 'Initializing replica from primary...';
          PGPASSWORD=$$REPLICA_PASSWORD pg_basebackup -h $$PRIMARY_HOST -p $$PRIMARY_PORT -U $$REPLICA_USER -D $$PGDATA -Fp -Xs -P -R;
        fi;
        postgres
      "

  # Redis 集群节点 - 使用Bitnami镜像
  redis-node-0:
    image: docker.io/bitnami/redis-cluster:7.2
    container_name: formalmath-redis-node-0
    environment:
      - 'REDIS_PASSWORD=${REDIS_PASSWORD:-redis_password}'
      - 'REDIS_CLUSTER_REPLICAS=1'
      - 'REDIS_NODES=redis-node-0,redis-node-1,redis-node-2,redis-node-3,redis-node-4,redis-node-5'
      - 'REDIS_CLUSTER_CREATOR=yes'
      - 'REDIS_CLUSTER_DYNAMIC_IPS=yes'
    ports:
      - "6379:6379"
    volumes:
      - redis_node0_data:/bitnami/redis/data
    networks:
      - formalmath-db
    restart: unless-stopped

  redis-node-1:
    image: docker.io/bitnami/redis-cluster:7.2
    container_name: formalmath-redis-node-1
    environment:
      - 'REDIS_PASSWORD=${REDIS_PASSWORD:-redis_password}'
      - 'REDIS_CLUSTER_REPLICAS=1'
      - 'REDIS_NODES=redis-node-0,redis-node-1,redis-node-2,redis-node-3,redis-node-4,redis-node-5'
    ports:
      - "6380:6379"
    volumes:
      - redis_node1_data:/bitnami/redis/data
    networks:
      - formalmath-db
    restart: unless-stopped

  redis-node-2:
    image: docker.io/bitnami/redis-cluster:7.2
    container_name: formalmath-redis-node-2
    environment:
      - 'REDIS_PASSWORD=${REDIS_PASSWORD:-redis_password}'
      - 'REDIS_CLUSTER_REPLICAS=1'
      - 'REDIS_NODES=redis-node-0,redis-node-1,redis-node-2,redis-node-3,redis-node-4,redis-node-5'
    ports:
      - "6381:6379"
    volumes:
      - redis_node2_data:/bitnami/redis/data
    networks:
      - formalmath-db
    restart: unless-stopped

  redis-node-3:
    image: docker.io/bitnami/redis-cluster:7.2
    container_name: formalmath-redis-node-3
    environment:
      - 'REDIS_PASSWORD=${REDIS_PASSWORD:-redis_password}'
      - 'REDIS_CLUSTER_REPLICAS=1'
      - 'REDIS_NODES=redis-node-0,redis-node-1,redis-node-2,redis-node-3,redis-node-4,redis-node-5'
    ports:
      - "6382:6379"
    volumes:
      - redis_node3_data:/bitnami/redis/data
    networks:
      - formalmath-db
    restart: unless-stopped

  redis-node-4:
    image: docker.io/bitnami/redis-cluster:7.2
    container_name: formalmath-redis-node-4
    environment:
      - 'REDIS_PASSWORD=${REDIS_PASSWORD:-redis_password}'
      - 'REDIS_CLUSTER_REPLICAS=1'
      - 'REDIS_NODES=redis-node-0,redis-node-1,redis-node-2,redis-node-3,redis-node-4,redis-node-5'
    ports:
      - "6383:6379"
    volumes:
      - redis_node4_data:/bitnami/redis/data
    networks:
      - formalmath-db
    restart: unless-stopped

  redis-node-5:
    image: docker.io/bitnami/redis-cluster:7.2
    container_name: formalmath-redis-node-5
    environment:
      - 'REDIS_PASSWORD=${REDIS_PASSWORD:-redis_password}'
      - 'REDIS_CLUSTER_REPLICAS=1'
      - 'REDIS_NODES=redis-node-0,redis-node-1,redis-node-2,redis-node-3,redis-node-4,redis-node-5'
    ports:
      - "6384:6379"
    volumes:
      - redis_node5_data:/bitnami/redis/data
    networks:
      - formalmath-db
    restart: unless-stopped

  # PgAdmin - PostgreSQL管理工具（可选）
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: formalmath-pgadmin
    environment:
      PGADMIN_DEFAULT_EMAIL: ${PGADMIN_EMAIL:-admin@formalmath.org}
      PGADMIN_DEFAULT_PASSWORD: ${PGADMIN_PASSWORD:-admin}
      PGADMIN_CONFIG_SERVER_MODE: 'False'
    ports:
      - "5050:80"
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    networks:
      - formalmath-db
    depends_on:
      - postgres-primary
    restart: unless-stopped
    profiles:
      - tools

  # Redis Commander - Redis管理工具（可选）
  redis-commander:
    image: rediscommander/redis-commander:latest
    container_name: formalmath-redis-commander
    environment:
      - REDIS_HOSTS=local:redis-node-0:6379:0:${REDIS_PASSWORD:-redis_password}
    ports:
      - "8081:8081"
    networks:
      - formalmath-db
    depends_on:
      - redis-node-0
    restart: unless-stopped
    profiles:
      - tools

  # 数据库备份服务
  db-backup:
    image: postgres:16-alpine
    container_name: formalmath-db-backup
    environment:
      PGHOST: postgres-primary
      PGPORT: 5432
      PGDATABASE: formalmath
      PGUSER: formalmath
      PGPASSWORD: ${DB_PASSWORD:-formalmath_password}
      BACKUP_DIR: /backup
      BACKUP_RETENTION_DAYS: "7"
    volumes:
      - ./backups:/backup
      - ./scripts/backup:/scripts:ro
    command: >
      sh -c "
        echo '0 2 * * * /scripts/postgresql_backup.sh full >> /var/log/backup.log 2>&1' | crontab - &&
        crond -f
      "
    networks:
      - formalmath-db
    depends_on:
      - postgres-primary
    restart: unless-stopped
    profiles:
      - backup

volumes:
  postgres_primary_data:
    driver: local
  postgres_replica1_data:
    driver: local
  postgres_replica2_data:
    driver: local
  redis_node0_data:
    driver: local
  redis_node1_data:
    driver: local
  redis_node2_data:
    driver: local
  redis_node3_data:
    driver: local
  redis_node4_data:
    driver: local
  redis_node5_data:
    driver: local
  pgadmin_data:
    driver: local

networks:
  formalmath-db:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
