# =============================================================================
# FormalMath API - 生产环境配置示例
# 复制此文件为 .env.production 并修改实际值
# =============================================================================

# ==================== 应用配置 ====================
APP_NAME=FormalMath API
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=production
API_PREFIX=/api/v1

# ==================== CORS配置 ====================
CORS_ORIGINS=["https://formalmath.org","https://app.formalmath.org"]

# ==================== PostgreSQL配置 ====================
# 主数据库（必需）- 使用PostgreSQL
DATABASE_URL=postgresql://formalmath:your_strong_password@db-primary.formalmath.org:5432/formalmath

# 只读副本（可选）- 用于读写分离
DATABASE_READ_REPLICA_URLS=["postgresql://formalmath:password@db-replica1.formalmath.org:5432/formalmath","postgresql://formalmath:password@db-replica2.formalmath.org:5432/formalmath"]

# 连接池配置
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# 查询超时配置（毫秒）
DATABASE_STATEMENT_TIMEOUT=60000
DATABASE_IDLE_IN_TRANSACTION_TIMEOUT=600000

# ==================== Redis配置 ====================
# Redis运行模式: standalone | sentinel | cluster
REDIS_MODE=cluster

# 单机模式配置（REDIS_MODE=standalone时使用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password

# 集群模式配置（REDIS_MODE=cluster时使用）
REDIS_CLUSTER_NODES=["redis-node1:6379","redis-node2:6379","redis-node3:6379","redis-node4:6379","redis-node5:6379","redis-node6:6379"]
REDIS_CLUSTER_PASSWORD=your_redis_password
REDIS_CLUSTER_SKIP_FULL_COVERAGE_CHECK=true

# Sentinel模式配置（REDIS_MODE=sentinel时使用）
REDIS_SENTINEL_HOSTS=["sentinel1:26379","sentinel2:26379","sentinel3:26379"]
REDIS_SENTINEL_MASTER_NAME=formalmath-master
REDIS_SENTINEL_PASSWORD=your_sentinel_password

# Redis连接池配置
REDIS_MAX_CONNECTIONS=100
REDIS_MIN_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# ==================== 缓存TTL配置（秒）====================
CACHE_TTL_KNOWLEDGE_GRAPH=3600
CACHE_TTL_LEARNING_PATH=1800
CACHE_TTL_USER_PROGRESS=300
CACHE_TTL_CONCEPT_INFO=7200
CACHE_TTL_DIAGNOSIS=600
CACHE_TTL_DEFAULT=300

# ==================== Celery配置 ====================
CELERY_BROKER_URL=redis://:password@redis-master:6379/1
CELERY_RESULT_BACKEND=redis://:password@redis-master:6379/2
CELERY_TIMEZONE=Asia/Shanghai

# ==================== 安全配置 ====================
# 生成强密钥: openssl rand -hex 32
SECRET_KEY=your_64_char_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 限流配置 ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=1000/minute

# ==================== 监控配置 ====================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
METRICS_ENABLED=true
METRICS_PORT=9090

# ==================== 外部服务配置 ====================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# 邮件服务
SMTP_HOST=smtp.formalmath.org
SMTP_PORT=587
SMTP_USER=noreply@formalmath.org
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@formalmath.org

# ==================== 备份配置 ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=formalmath-backups
BACKUP_S3_PREFIX=backups/production

# AWS凭证（用于备份上传）
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
