# FormalMath API 环境变量配置示例
# 复制为 .env 文件并修改实际值

# ==================== 应用配置 ====================
APP_NAME=FormalMath API
APP_VERSION=2.0.0
DEBUG=false
API_PREFIX=/api/v1

# ==================== CORS配置 ====================
CORS_ORIGINS=["*"]

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_password_here
REDIS_MAX_CONNECTIONS=100

# 或者使用Redis URL
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://:password@localhost:6379/0

# ==================== 缓存TTL配置（秒） ====================
CACHE_TTL_KNOWLEDGE_GRAPH=3600
CACHE_TTL_LEARNING_PATH=1800
CACHE_TTL_USER_PROGRESS=300
CACHE_TTL_CONCEPT_INFO=7200
CACHE_TTL_DIAGNOSIS=600

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./formalmath.db
# MySQL示例: mysql+pymysql://user:password@localhost/formalmath
# PostgreSQL示例: postgresql://user:password@localhost/formalmath

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ==================== Celery配置 ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TIMEZONE=Asia/Shanghai

# ==================== 分页配置 ====================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ==================== 压缩配置 ====================
COMPRESSION_MINIMUM_SIZE=1024
COMPRESSION_LEVEL=6

# ==================== 性能配置 ====================
WORKERS=4
