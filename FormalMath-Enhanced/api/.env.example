# ============================================
# FormalMath API 环境变量配置示例
# ============================================

# 应用配置
APP_NAME="FormalMath API"
APP_VERSION="2.0.0"
DEBUG=false
API_PREFIX="/api/v1"

# 数据库配置
DATABASE_URL="sqlite:///./formalmath.db"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis配置
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery配置
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ============================================
# 邮件服务配置
# ============================================

# 邮件服务提供商: sendgrid, aws_ses, smtp
EMAIL_PROVIDER="sendgrid"

# 发件人配置
EMAIL_FROM_NAME="FormalMath"
EMAIL_FROM_ADDRESS="noreply@formalmath.edu"
EMAIL_REPLY_TO="support@formalmath.edu"

# SendGrid 配置
SENDGRID_API_KEY="your_sendgrid_api_key_here"

# AWS SES 配置
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
AWS_SES_CONFIGURATION_SET="formalmath_emails"

# SMTP 配置（备用）
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_USE_TLS=true

# 邮件队列配置
EMAIL_QUEUE_ENABLED=true
EMAIL_QUEUE_NAME="email_notifications"
EMAIL_RETRY_MAX_ATTEMPTS=3
EMAIL_RETRY_DELAY=60
EMAIL_RATE_LIMIT=100

# 邮件模板配置
EMAIL_DEFAULT_LANGUAGE="zh_CN"

# 邮件追踪配置
EMAIL_TRACKING_ENABLED=true

# 邮件统计配置
EMAIL_STATS_RETENTION_DAYS=90
