# FormalMath - 生产环境Docker Compose配置
# 包含：Nginx反向代理、FastAPI后端、React前端、Redis缓存、Celery工作节点

version: '3.8'

services:
  # Nginx反向代理
  nginx:
    image: nginx:alpine
    container_name: formalmath-nginx
    ports:
      - "80:80'
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/nginx/ssl:ro
      - nginx-cache:/var/cache/nginx
    depends_on:
      - backend
      - frontend
    networks:
      - formalmath-network
    healthcheck:
      test: ['CMD", "curl', "-f", 'http://localhost/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    restart: unless-stopped
    logging:
      driver: "json-file'
      options:
        max-size: "10m"
        max-file: '3"

  # FastAPI后端服务
  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: formalmath-backend
    environment:
      - DEBUG=false
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_DB=0
      - CELERY_BROKER_URL=redis://redis:6379/1
      - CELERY_RESULT_BACKEND=redis://redis:6379/2
      - DATABASE_URL=sqlite:///app/data/formalmath.db
      - DATABASE_POOL_SIZE=20
      - CORS_ORIGINS=["*']
      - WORKERS=4
      - REQUEST_TIMEOUT=30
    volumes:
      - backend-data:/app/data
      - ./api:/app:ro
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - formalmath-network
    healthcheck:
      test: ["CMD", 'curl", "-f', "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '2'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 512M
    logging:
      driver: 'json-file"
      options:
        max-size: "10m'
        max-file: "3"

  # 前端静态文件服务（开发/备选）
  frontend:
    build:
      context: .
      dockerfile: Dockerfile.frontend
    container_name: formalmath-frontend
    environment:
      - NODE_ENV=production
      - VITE_API_URL=/api/v1
    depends_on:
      - backend
    networks:
      - formalmath-network
    healthcheck:
      test: ['CMD", "curl', "-f", 'http://localhost:80/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    restart: unless-stopped
    logging:
      driver: "json-file'
      options:
        max-size: "10m"
        max-file: '3"

  # Redis缓存和消息队列
  redis:
    image: redis:7-alpine
    container_name: formalmath-redis
    command: redis-server --appendonly yes --maxmemory 512mb --maxmemory-policy allkeys-lru
    volumes:
      - redis-data:/data
    networks:
      - formalmath-network
    healthcheck:
      test: ["CMD', "redis-cli", 'ping"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M
    logging:
      driver: "json-file'
      options:
        max-size: "10m"
        max-file: '3"

  # Celery工作节点 - 处理异步任务
  celery-worker:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: formalmath-celery-worker
    command: celery -A celery_worker worker --loglevel=info --concurrency=4
    environment:
      - DEBUG=false
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - CELERY_BROKER_URL=redis://redis:6379/1
      - CELERY_RESULT_BACKEND=redis://redis:6379/2
      - DATABASE_URL=sqlite:///app/data/formalmath.db
    volumes:
      - backend-data:/app/data
    depends_on:
      redis:
        condition: service_healthy
      backend:
        condition: service_healthy
    networks:
      - formalmath-network
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 1G
    logging:
      driver: "json-file'
      options:
        max-size: "10m"
        max-file: '3"

  # Celery定时任务调度器
  celery-beat:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: formalmath-celery-beat
    command: celery -A celery_beat beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler
    environment:
      - DEBUG=false
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - CELERY_BROKER_URL=redis://redis:6379/1
      - CELERY_RESULT_BACKEND=redis://redis:6379/2
      - DATABASE_URL=sqlite:///app/data/formalmath.db
    volumes:
      - backend-data:/app/data
      - celery-beat-data:/app/celerybeat
    depends_on:
      redis:
        condition: service_healthy
      celery-worker:
        condition: service_started
    networks:
      - formalmath-network
    restart: unless-stopped
    logging:
      driver: "json-file'
      options:
        max-size: "10m"
        max-file: '3"

  # 监控 - Prometheus（可选）
  prometheus:
    image: prom/prometheus:latest
    container_name: formalmath-prometheus
    ports:
      - "9090:9090'
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/usr/share/prometheus/console_libraries'
      - '--web.console.templates=/usr/share/prometheus/consoles'
      - '--storage.tsdb.retention.time=200h'
      - '--web.enable-lifecycle'
    networks:
      - formalmath-network
    profiles:
      - monitoring
    restart: unless-stopped

  # 监控 - Grafana（可选）
  grafana:
    image: grafana/grafana:latest
    container_name: formalmath-grafana
    ports:
      - "3000:3000"
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=admin
      - GF_USERS_ALLOW_SIGN_UP=false
    volumes:
      - grafana-data:/var/lib/grafana
      - ./monitoring/grafana/dashboards:/etc/grafana/provisioning/dashboards:ro
      - ./monitoring/grafana/datasources:/etc/grafana/provisioning/datasources:ro
    networks:
      - formalmath-network
    profiles:
      - monitoring
    restart: unless-stopped

networks:
  formalmath-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16

volumes:
  backend-data:
    driver: local
  redis-data:
    driver: local
  celery-beat-data:
    driver: local
  nginx-cache:
    driver: local
  prometheus-data:
    driver: local
  grafana-data:
    driver: local
