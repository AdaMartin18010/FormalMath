# ============================================
# FormalMath - 生产环境变量配置
# ============================================

# --------------------------------------------
# 应用基础配置
# --------------------------------------------
APP_NAME=FormalMath
APP_ENV=production
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-secure-secret-key-change-in-production

# --------------------------------------------
# 服务器配置
# --------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4
REQUEST_TIMEOUT=30
MAX_REQUESTS=10000
MAX_REQUESTS_JITTER=1000

# --------------------------------------------
# 数据库配置（SQLite - 生产环境建议使用PostgreSQL）
# --------------------------------------------
DATABASE_URL=sqlite:///app/data/formalmath.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# PostgreSQL配置（推荐用于生产环境）
# DATABASE_URL=postgresql://user:password@postgres:5432/formalmath
# POSTGRES_USER=formalmath
# POSTGRES_PASSWORD=your-secure-password
# POSTGRES_DB=formalmath

# --------------------------------------------
# Redis配置
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_CONNECTION_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# --------------------------------------------
# Celery配置
# --------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true

# --------------------------------------------
# API配置
# --------------------------------------------
API_V1_PREFIX=/api/v1
API_TITLE=FormalMath API
API_VERSION=1.0.0
API_DESCRIPTION=形式化数学学习平台API

# --------------------------------------------
# CORS配置
# --------------------------------------------
CORS_ORIGINS=["https://formalmath.example.com","https://www.formalmath.example.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# --------------------------------------------
# 安全配置
# --------------------------------------------
# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码哈希
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_MIN_LENGTH=8

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/formalmath.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# --------------------------------------------
# 邮件配置（用于通知和验证）
# --------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@formalmath.example.com

# --------------------------------------------
# 监控配置
# --------------------------------------------
SENTRY_DSN=
METRICS_ENABLED=true
METRICS_PORT=9090

# --------------------------------------------
# 外部服务配置
# --------------------------------------------
LEAN4_SERVER_URL=http://lean4:8080
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --------------------------------------------
# 备份配置
# --------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
