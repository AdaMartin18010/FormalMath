# API 服务告警规则
# 定义 API 相关的监控告警

groups:
  - name: api_availability
    interval: 30s
    rules:
      # API 可用性告警
      - alert: APIHighErrorRate
        expr: |
          (
            sum(rate(http_requests_total{status=~"5.."}[5m])) by (service)
            /
            sum(rate(http_requests_total[5m])) by (service)
          ) > 0.05
        for: 2m
        labels:
          severity: critical
          team: backend
        annotations:
          summary: "API {{ $labels.service }} 错误率过高"
          description: "服务 {{ $labels.service }} 的错误率超过 5%，当前值: {{ $value | humanizePercentage }}"
          runbook_url: "https://wiki.internal/formalmath/runbooks/api-high-error-rate"

      # API 响应时间告警
      - alert: APIHighLatency
        expr: |
          histogram_quantile(0.95, 
            sum(rate(http_request_duration_seconds_bucket[5m])) by (service, le)
          ) > 1
        for: 3m
        labels:
          severity: warning
          team: backend
        annotations:
          summary: "API {{ $labels.service }} 响应延迟过高"
          description: "服务 {{ $labels.service }} 的 P95 响应时间超过 1s，当前值: {{ $value | humanizeDuration }}"

      # API 完全不可用告警
      - alert: APIDown
        expr: up{job=~"formalmath-api|adaptive-learning-backend|cognitive-diagnosis|evaluation-system"} == 0
        for: 1m
        labels:
          severity: critical
          team: backend
        annotations:
          summary: "API 服务 {{ $labels.instance }} 宕机"
          description: "服务 {{ $labels.job }} ({{ $labels.instance }}) 已经连续 1 分钟无响应"

  - name: api_performance
    interval: 30s
    rules:
      # 请求速率异常告警
      - alert: APITrafficDrop
        expr: |
          (
            sum(rate(http_requests_total[5m])) by (service)
            /
            avg_over_time(sum(rate(http_requests_total[5m])) by (service)[1h:5m])
          ) < 0.3
        for: 5m
        labels:
          severity: warning
          team: backend
        annotations:
          summary: "API {{ $labels.service }} 流量骤降"
          description: "服务 {{ $labels.service }} 的请求量降至平均值的 30% 以下"

      # 数据库连接池告警
      - alert: DatabaseConnectionPoolHigh
        expr: |
          database_connections_active / database_connections_max > 0.8
        for: 2m
        labels:
          severity: warning
          team: backend
        annotations:
          summary: "数据库连接池使用率过高"
          description: "数据库连接池使用率达到 {{ $value | humanizePercentage }}"

      # Redis 连接告警
      - alert: RedisConnectionFailed
        expr: redis_connected_clients == 0
        for: 30s
        labels:
          severity: critical
          team: backend
        annotations:
          summary: "Redis 连接失败"
          description: "无法连接到 Redis 服务器"

  - name: api_security
    interval: 30s
    rules:
      # 异常请求频率告警（可能的攻击）
      - alert: HighRequestRateFromIP
        expr: |
          sum(rate(http_requests_total[1m])) by (remote_ip) > 100
        for: 2m
        labels:
          severity: warning
          team: security
        annotations:
          summary: "来自 {{ $labels.remote_ip }} 的高频请求"
          description: "IP {{ $labels.remote_ip }} 的请求频率异常高"

      # 401/403 错误率告警（认证失败）
      - alert: HighAuthFailureRate
        expr: |
          (
            sum(rate(http_requests_total{status=~"401|403"}[5m]))
            /
            sum(rate(http_requests_total[5m]))
          ) > 0.1
        for: 5m
        labels:
          severity: warning
          team: security
        annotations:
          summary: "认证失败率过高"
          description: "认证失败率达到 {{ $value | humanizePercentage }}"
