/-
**定理**：Cohen力迫添加连续统的实数

通过添加κ > ℵ₀个Cohen实数，
可以使2^ℵ₀ = κ。
-/
def CohenForcing (κ : Cardinal) : ForcingPoset (Finset (κ × ℕ × Bool)) :=
  -- Cohen力迫偏序集：有限个条件的集合
  {
    le := fun p q => q ⊆ p,  -- 反包含作为序
    compat := fun p q => ∃ r, r ⊆ p ∧ r ⊆ q,
    has_bottom := ⟨∅, by simp⟩
  }

theorem cohen_forcing_continuum {M : ZFSet} (hM : M ⊨ ZF)
    (κ : Cardinal) (hκ : ℵ₀ ≤ κ) (hcountable : Countable M) :
    ∃ G : Set (Finset (κ × ℕ × Bool)), 
      GenericFilter (CohenForcing κ) M G ∧ 
      M[G] ⊨ (2 ^ ℵ₀ = κ) := by
