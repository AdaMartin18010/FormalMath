/-
## 模型范畴的纤维-余纤维分解

在模型范畴中，任何态射都可以分解为余纤维映射接平凡纤维映射。
-/

class ModelCategory (C : Type u) [Category.{v} C] where
  fibrations : MorphismProperty C
  cofibrations : MorphismProperty C
  weakEquivalences : MorphismProperty C
  twoOutOfThree : ∀ {X Y Z} (f : X ⟶ Y) (g : Y ⟶ Z), 
    weakEquivalences f → weakEquivalences g → weakEquivalences (f ≫ g)
  retract : ∀ {X Y} {f g : X ⟶ Y}, 
    fibrations f → Retract f g → fibrations g
  lifting : ∀ {A B X Y} {i : A ⟶ B} {p : X ⟶ Y},
    cofibrations i → fibrations p → weakEquivalences p → 
    ∀ (u : A ⟶ X) (v : B ⟶ Y), i ≫ v = u ≫ p → ∃ w, i ≫ w = u ∧ w ≫ p = v
  factorization : ∀ {X Y} (f : X ⟶ Y), 
    ∃ (Z : C) (i : X ⟶ Z) (p : Z ⟶ Y), 
      cofibrations i ∧ fibrations p ∧ weakEquivalences p ∧ i ≫ p = f

theorem model_category_factorization {C : Type u} [Category.{v} C] [ModelCategory C] :
    ∀ {X Y} (f : X ⟶ Y), 
    ∃ (Z : C) (i : X ⟶ Z) (p : Z ⟶ Y), 
      ModelCategory.cofibrations i ∧ ModelCategory.fibrations p ∧ 
      ModelCategory.weakEquivalences i ∧ i ≫ p = f := by
