/-
## ∞-范畴的单纯形 nerve 构造

范畴C的 nerve NC 是一个单纯形集，当C是∞-范畴时，
NC满足弱Kan条件（inner horn filling）。
-/

structure SSet where
  obj : ℕ → Type v
  map : ∀ {m n}, (Fin m → Fin n) → obj n → obj m

def Nerve (C : Type u) [Category.{v} C] : SSet where
  obj n := Fin n → C
  map f := fun x i => x (f i)

class QuasiCategory (C : Type u) [Category.{v} C] where
  innerHornFilling : ∀ (n : ℕ) (i : Fin (n+1)), 0 < i.val → i.val < n → 
    ∀ (Λ : SSet), ∃ (σ : Nerve C).obj n, True

theorem nerve_inner_horn_filling {C : Type u} [Category.{v} C] [QuasiCategory C] :
    ∀ (n : ℕ) (i : Fin (n+1)), 0 < i.val → i.val < n → 
