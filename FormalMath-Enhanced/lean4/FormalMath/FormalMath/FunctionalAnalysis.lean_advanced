    [TopologicalAddGroup E] [ContinuousSMul ℝ E] {K : Set E}
    (hK_compact : IsCompact K) (hK_convex : Convex ℝ K) :
    K = closure (convexHull ℝ {x | ExtremePoint x}) := by
