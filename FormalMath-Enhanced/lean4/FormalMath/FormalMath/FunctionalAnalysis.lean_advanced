/-
## 谱理论基本概念

对于Banach空间上的有界线性算子，
可以定义谱、预解集等概念。

这是泛函分析的核心内容。
-/

/-- 谱 -/
def Spectrum {E : Type*} [BanachSpace E] (T : E →L[ℝ] E) : Set ℂ :=
  {λ : ℂ | ¬ Invertible (T - λ • ContinuousLinearMap.id ℝ E)}

/-- 预解集 -/
def ResolventSet {E : Type*} [BanachSpace E] (T : E →L[ℝ] E) : Set ℂ :=
  (Spectrum T)ᶜ

/-- 谱半径公式 -/
theorem spectral_radius_formula {E : Type*} [BanachSpace E] {T : E →L[ℝ] E} :
    let r := sSup {‖λ‖ | λ ∈ Spectrum T}
    r = limsup (fun n ↦ ‖T ^ n‖ ^ (1 / n : ℝ)) atTop := by
  -- Gelfand谱半径公式
  sorry

/-
## 弱收敛与强收敛

在无限维空间中，弱收敛比强收敛更常见。

弱收敛：∀f ∈ E*, f(x_n) → f(x)
强收敛：‖x_n - x‖ → 0
-/

/-- 弱收敛 -/
def ConvergesWeakly {E : Type*} [NormedAddCommGroup E] [Module ℝ E]
    [TopologicalSpace E] (x : ℕ → E) (x₀ : E) : Prop :=
  ∀ f : E →L[ℝ] ℝ, Tendsto (fun n ↦ f (x n)) atTop (𝓝 (f x₀))

/-- 自反Banach空间的有界序列有弱收敛子列 -/
theorem eberlein_smulyan {E : Type*} [BanachSpace E] [ReflexiveSpace E]
    {x : ℕ → E} (h_bounded : Bornology.IsBounded (Set.range x)) :
    ∃ φ : ℕ → ℕ, StrictMono φ ∧ ∃ x₀, ConvergesWeakly (x ∘ φ) x₀ := by
  -- Eberlein-Šmulian定理
  sorry

/-- 自反空间 -/
class ReflexiveSpace (E : Type*) [BanachSpace E] : Prop where
  reflexive : ∀ x : (E →L[ℝ] ℝ) →L[ℝ] ℝ, ∃ y : E, ∀ f, x f = f y

/-
## 投影定理与正交分解

在Hilbert空间中，闭子空间上的正交投影存在唯一。

这是Hilbert空间几何的基础。
-/

/-- 正交投影 -/
def OrthogonalProjection {H : Type*} [HilbertSpace H] (M : Submodule ℝ H) 
    (hM_closed : IsClosed (M : Set H)) : H → H :=
  fun x ↦ Classical.choose (exists_projection x M hM_closed)

/-- 投影存在性 -/
theorem exists_projection {H : Type*} [HilbertSpace H] (x : H) 
    (M : Submodule ℝ H) (hM_closed : IsClosed (M : Set H)) :
    ∃! y ∈ M, ∀ z ∈ M, ‖x - y‖ ≤ ‖x - z‖ := by
  -- 证明：利用平行四边形法则
  -- 证明极小化序列是Cauchy列
  sorry

/-- 正交分解 -/
theorem orthogonal_decomposition {H : Type*} [HilbertSpace H] 
    (M : Submodule ℝ H) (hM_closed : IsClosed (M : Set H)) (x : H) :
    ∃! y ∈ M, ∃! z ∈ Mᗮ, x = y + z := by
  -- y是x在M上的投影，z = x - y
  sorry

/-- 正交补 -/
def OrthogonalComplement {H : Type*} [HilbertSpace H] 
    (M : Submodule ℝ H) : Submodule ℝ H :=
  { carrier := {x | ∀ y ∈ M, inner x y = 0}
    zero_mem' := by simp
    add_mem' := by
      intro x y hx hy z hz
      simp [inner_add_left, hx z hz, hy z hz]
    smul_mem' := by
      intro c x hx y hy
      simp [inner_smul_left, hx y hy]
  }

notation M "ᗮ" => OrthogonalComplement M

