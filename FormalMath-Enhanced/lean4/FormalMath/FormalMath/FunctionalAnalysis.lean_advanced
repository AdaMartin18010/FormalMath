/-
## Lax-Milgram定理

这是研究椭圆型偏微分方程的重要工具。

设H是Hilbert空间，a : H×H → ℝ是有界、强制的双线性形式，
则对任意f ∈ H*，存在唯一的u ∈ H使得
a(u, v) = f(v) 对所有v ∈ H成立。
-/

/-- 双线性形式 -/
structure BilinearForm (H : Type*) [HilbertSpace H] where
  toFun : H → H → ℝ
  linear_left : ∀ y, IsLinearMap ℝ (fun x ↦ toFun x y)
  linear_right : ∀ x, IsLinearMap ℝ (toFun x)

/-- 有界双线性形式 -/
def BoundedBilinearForm {H : Type*} [HilbertSpace H] (a : BilinearForm H) : Prop :=
  ∃ C > 0, ∀ x y, |a.toFun x y| ≤ C * ‖x‖ * ‖y‖

/-- 强制双线性形式 -/
def CoerciveBilinearForm {H : Type*} [HilbertSpace H] (a : BilinearForm H) : Prop :=
  ∃ α > 0, ∀ x, a.toFun x x ≥ α * ‖x‖ ^ 2

/-- Lax-Milgram定理 -/
theorem lax_milgram {H : Type*} [HilbertSpace H] {a : BilinearForm H}
    (h_bounded : BoundedBilinearForm a)
    (h_coercive : CoerciveBilinearForm a)
    {f : H →L[ℝ] ℝ} :
    ∃! u : H, ∀ v, a.toFun u v = f v := by
