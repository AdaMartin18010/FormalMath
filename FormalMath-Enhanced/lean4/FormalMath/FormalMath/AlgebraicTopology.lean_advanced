/-
## 同伦群 (Homotopy Groups)

同伦群πₙ(X, x₀)是代数拓扑的基本不变量。

- π₁是基本群（可能非交换）
- n ≥ 2时，πₙ是交换群

同伦群完全刻画了空间的同伦型（Whitehead定理）。
-/

/-- n维球面 -/
def Sphere (n : ℕ) : Type :=
  {x : Fin (n + 1) → ℝ | ∑ i, x i ^ 2 = 1}

/-- n阶同伦群 -/
def HomotopyGroup (n : ℕ) (X : Type u) [TopologicalSpace X] (x₀ : X) : Type u :=
  {f : Sphere n → X | Continuous f ∧ f (fun _ ↦ 1) = x₀} /-
    同伦关系 -/

instance (n : ℕ) (X : Type u) [TopologicalSpace X] (x₀ : X) : 
    Group (HomotopyGroup n X x₀) := sorry

/-- 高阶同伦群是交换群 -/
instance (n : ℕ) (X : Type u) [TopologicalSpace X] (x₀ : X) :
    CommGroup (HomotopyGroup (n + 1) X x₀) := sorry

