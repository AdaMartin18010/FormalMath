/-
## Künneth公式

Künneth公式计算乘积空间的同调。

对于空间X和Y，
Hₙ(X × Y) ≅ ⊕_{i+j=n} Hᵢ(X) ⊗ Hⱼ(Y) ⊕ ⊕_{i+j=n-1} Tor(Hᵢ(X), Hⱼ(Y))
-/

theorem kuenneth_formula {X Y : Type u} [TopologicalSpace X] [TopologicalSpace Y]
    (n : ℕ) [CompactSpace X] [CompactSpace Y] :
    let LHS := HomologyGroup n (X × Y)
    let RHS := 
      (⊕_{p + q = n} HomologyGroup p X ⊗ HomologyGroup q Y) ⊕
      (⊕_{p + q = n - 1} Tor 1 (HomologyGroup p X) (HomologyGroup q Y))
    LHS ≅ RHS := by
  -- 利用Eilenberg-Zilber定理和万有系数定理
  sorry

