/-- 单连通 -/
def SimplyConnected (U : Set ℂ) : Prop :=
  IsConnected U ∧ ∀ γ : ℝ → ℂ, Differentiable ℝ γ → 
    (∀ t, γ t ∈ U) → γ 0 = γ 1 → 
    ∃ F : ℝ × ℝ → ℂ, Continuous F ∧ 
      F 0 = γ ∧ ∀ s, F 1 s = F 0 0

