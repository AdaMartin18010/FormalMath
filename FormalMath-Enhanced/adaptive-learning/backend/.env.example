# FormalMath 自适应学习系统配置

# 应用配置
DEBUG=True
APP_NAME="FormalMath Adaptive Learning System"

# 数据库
DATABASE_URL=sqlite:///./adaptive_learning.db

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 知识图谱路径
KNOWLEDGE_GRAPH_PATH=../../../project/links/cross-branch-links.yaml

# 学习路径算法配置
DEFAULT_ALGORITHM=astar
MAX_PATH_LENGTH=50
DIFFICULTY_WEIGHT=0.3
PREREQUISITE_WEIGHT=0.4
INTEREST_WEIGHT=0.3

# 自适应调整参数
MASTERY_THRESHOLD=0.8
STRUGGLE_THRESHOLD=0.4
ADJUSTMENT_SENSITIVITY=0.2

# 推荐系统配置
MAX_RECOMMENDATIONS=10
MIN_CONFIDENCE=0.6
