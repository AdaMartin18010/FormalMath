def IsDiagonalizable {n : Type*} [Fintype n] [DecidableEq n] {α : Type*} [Field α]
  (A : Matrix n n α) : Prop :=
  ∃ P D : Matrix n n α,
    InvertibleMatrix P ∧
    D = Matrix.diagonal (fun i => D i i) ∧
    A = P * D * P⁻¹

