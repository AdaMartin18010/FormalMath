# probability-space.yaml - 概率空间概念知识图谱节点
# FormalMath Knowledge Graph - Concept Node
# Created: 2025-12-01

concept:
  id: "probability-space'
  name:
    zh: '概率空间"
    en: 'Probability Space"
  msc_codes: ['60A05']
  
  # ===== 定义层 =====
  definition:
    formal: |
      概率空间是三元组 (Ω, ℱ, P)，其中：
      1. Ω 是样本空间（所有可能结果的集合）
      2. ℱ ⊆ 𝒫(Ω) 是事件σ-代数
      3. P: ℱ → [0,1] 是概率测度，满足：
         - P(Ω) = 1
         - 可列可加性：P(⋃ₙAₙ) = Σₙ P(Aₙ) 对于两两不交的Aₙ
      
    informal: |
      概率空间是描述随机实验的数学框架。
      
      掷骰子的例子：
      - Ω = {1, 2, 3, 4, 5, 6}（所有可能点数）
      - ℱ = 所有子集（64个事件）
      - P({k}) = 1/6（均匀分布）
      
    lean: |
      -- Mathlib定义
      class MeasureTheory.IsProbabilityMeasure (μ : Measure Ω) : Prop where
        measure_univ : μ Set.univ = 1
        
      structure ProbabilitySpace (Ω : Type*) extends MeasurableSpace Ω where
        P : Measure Ω
        isProb : IsProbabilityMeasure P
        
  # ===== 直觉层 =====
  intuition:
    geometric: |
      【几何直觉】概率分布
      - Ω是"所有可能性的空间"
      - P给每个区域赋予'权重'
      - 总权重为1
      
    algebraic: |
      【代数直觉】测度论特例
      - 概率测度是归一化测度
      - σ-代数是可测事件的代数
      - 可列可加性 = 无穷划分
      
    physical: |
      【物理直觉】不确定性
      - Ω = 系统所有可能状态
      - P(A) = 观测到A的频率极限
      - 量子力学：概率幅的模方
      
  # ===== 表征层 =====
  representations:
    - type: "韦恩图'
      content: |
        概率空间的图示：
        
        ┌───────────────────────┐
        │          Ω            │  P(Ω) = 1
        │   ┌─────┐  ┌─────┐   │
        │   │  A  │  │  B  │   │  P(A), P(B)
        │   │ ┌───┼──┼───┐ │   │
        │   │ │A∩B│  │   │ │   │  P(A∩B)
        │   └─┼───┘  └───┼─┘   │
        │     └──────────┘     │
        └───────────────────────┘
        
    - type: "公理系统'
      content: |
        Kolmogorov公理：
        1. P(A) ≥ 0
        2. P(Ω) = 1
        3. P(⋃ₙAₙ) = ΣₙP(Aₙ) (Aₙ两两不交)
        
  # ===== 例子层 =====
  examples:
    discrete:
      - name: '掷硬币"
        omega: "{H, T}'
        sigma: '𝒫(Ω)"
        measure: 'P({H}) = P({T}) = 1/2"
        
      - name: '掷骰子'
        omega: "{1,2,3,4,5,6}"
        sigma: '𝒫(Ω)'
        measure: "P({k}) = 1/6'
        
    continuous:
      - name: "[0,1]上均匀分布'
        omega: '[0,1]"
        sigma: "Borel σ-代数'
        measure: 'P([a,b]) = b - a"
        
      - name: '正态分布"
        omega: 'ℝ'
        sigma: "Borel σ-代数"
        measure: 'P = N(μ, σ²)'
        density: "(2πσ²)^{-1/2} exp(-(x-μ)²/2σ²)'
        
  # ===== 关系层 =====
  relations:
    requires:
      - id: "measure'
        description: '概率测度是测度的特例"
      - id: "sigma-algebra'
        description: '事件形成σ-代数"
        
    generalizes:
      - id: 'finite-probability"
        description: '有限概率空间'
        
    specialized_by:
      - id: "discrete-probability"
        description: '离散概率空间'
      - id: "continuous-probability'
        description: "连续概率空间'
        
    related_to:
      - id: 'random-variable"
        description: "随机变量定义在概率空间上'
      - id: 'expectation"
        description: '期望是Lebesgue积分"
        
  # ===== 定理层 =====
  key_theorems:
    - id: 'law-of-large-numbers'
      statement: "样本均值收敛到期望"
      importance: 5
      
    - id: 'central-limit-theorem'
      statement: "标准化和分布收敛到正态'
      importance: 5
      
    - id: "borel-cantelli'
      statement: '关于无穷多事件发生的概率"
      importance: 4
      
  # ===== 元数据层 =====
  metadata:
    difficulty: 3
    importance: 5
    
    prerequisites:
      - "measure'
      - 'sigma-algebra"
      
    leads_to:
      - 'random-variable"
      - 'stochastic-process'
      - "statistical-inference"
      
    history:
      first_appearance: 1933
      context: 'Kolmogorov公理化'
      
  # ===== Mathlib对齐 =====
  mathlib:
    path: "Mathlib.Probability.ProbabilityMassFunction.Basic'
    name: "MeasureTheory.IsProbabilityMeasure'
    coverage: 'complete"
