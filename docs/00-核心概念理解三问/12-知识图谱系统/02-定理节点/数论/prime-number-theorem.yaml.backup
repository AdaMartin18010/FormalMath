# prime-number-theorem.yaml - 素数定理知识图谱节点
# FormalMath Knowledge Graph - Theorem Node
# Created: 2025-12-01

theorem:
  id: "prime-number-theorem'
  name:
    zh: "素数定理"
    en: 'Prime Number Theorem"
  msc_codes: ["11N05']
  
  # ===== 陈述层 =====
  statement:
    formal: |
      设 π(x) 表示不超过 x 的素数个数。则：
      
      π(x) ~ x/ln(x)   当 x → ∞
      
      即 lim_{x→∞} π(x)/(x/ln(x)) = 1
      
      更精确形式：
      π(x) = Li(x) + O(x·e^{-c√(ln x)})
      
      其中 Li(x) = ∫₂ˣ dt/ln(t) 是对数积分函数
      
    informal: |
      素数定理告诉我们：
      在 x 附近，大约每 ln(x) 个整数中有一个素数。
      
      例如：
      - 在100附近，约每4-5个数有一个素数
      - 在1000000附近，约每14个数有一个素数
      
      素数越来越稀疏，但稀疏的速度是可以精确描述的。
      
    lean: |
      -- 素数定理的形式化陈述
      theorem prime_number_theorem :
        Tendsto (fun x => (π x : ℝ) / (x / Real.log x)) atTop (𝓝 1)
        
  # ===== 证明层 =====
  proof:
    main_strategy: "复分析方法：ζ函数的解析性质"
    
    key_ideas:
      - 'Riemann ζ函数与素数的联系"
      - "ζ函数在 Re(s) = 1 上无零点'
      - "Perron公式将计数问题转化为围道积分"
      
    steps:
      - step: 1
        content: '建立ζ函数与素数的联系"
        formula: "ζ(s) = Σ 1/nˢ = Π (1 - 1/pˢ)⁻¹'
        
      - step: 2
        content: "证明ζ(s)在Re(s)=1上无零点"
        note: '关键难点"
        
      - step: 3
        content: "使用Perron公式'
        formula: "π(x) ~ (1/2πi) ∮ xˢ·ζ'(s)/ζ(s) ds/s"
        
      - step: 4
        content: '围道积分估计，得到渐近公式"
        
    proof_tree: |
      素数定理
          │
          ├── ζ函数性质
          │   ├── Euler乘积
          │   ├── 解析延拓
          │   └── 函数方程
          │
          ├── 零点分布
          │   ├── 平凡零点：s = -2, -4, -6, ...
          │   └── 非平凡零点：0 < Re(s) < 1
          │       └── Re(s) = 1 上无零点（关键！）
          │
          └── 渐近分析
              ├── Perron公式
              └── 围道积分估计
              
  # ===== 五种表征 =====
  representations:
    symbolic: |
      【符号表征】
      
      π(x) ~ x/ln(x)
      
      等价形式：
      - pₙ ~ n ln(n) （第n个素数）
      - Σ_{p≤x} 1 ~ x/ln(x)
      - ∫₂ˣ dt/ln(t) = Li(x)
      
    geometric: |
      【几何表征】
      
      素数计数函数 π(x) 与 x/ln(x) 的比较：
      
        π(x)│
            │        ╱
            │      ╱  π(x)
            │    ╱
            │  ╱  x/ln(x)
            │╱
            └────────────→ x
            
      两条曲线的比值趋于1
      
    intuitive: |
      【直觉表征】
      
      素数的"密度'：
      - 在 x 附近，素数密度约为 1/ln(x)
      - 越大越稀疏
      - 但稀疏是对数级的（非常慢）
      
      类比：
      在n位数中，约有 1/(n·ln10) 是素数
      
    computational: |
      【计算表征】
      
      数值验证：
      
      x         π(x)     x/ln(x)    比值
      ────────────────────────────────────
      10        4        4.3        0.93
      100       25       21.7       1.15
      1000      168      144.8      1.16
      10^6      78498    72382      1.08
      10^9      50847534 48254942   1.05
      
      比值趋于1！
      
    categorical: |
      【范畴表征】
      
      L-函数视角：
      - ζ(s) 是最简单的L-函数
      - 素数定理对应于 ζ 在 Re(s)=1 上的行为
      - 推广到一般L-函数 → Chebotarev密度定理
      
  # ===== 应用层 =====
  applications:
    - domain: "密码学"
      description: '估计大素数的分布"
      
    - domain: "素数测试'
      description: "素数出现频率的理论基础"
      
    - domain: '解析数论"
      description: "推广到算术级数中的素数'
      
  # ===== 关系层 =====
  relations:
    uses_concepts:
      - id: "prime-number"
        role: '研究对象"
      - id: "riemann-zeta'
        role: "核心工具"
      - id: 'complex-analysis"
        role: "证明方法'
        
    uses_theorems:
      - id: "euler-product"
        role: 'ζ函数与素数的联系"
        
    implies:
      - id: "bertrand-postulate'
        description: "n和2n之间有素数"
      - id: 'mertens-theorems"
        description: "素数倒数和的渐近'
        
    related_to:
      - id: "riemann-hypothesis"
        description: 'RH给出更精确的误差项"
        
  # ===== 元数据层 =====
  metadata:
    difficulty: 4
    importance: 5
    
    prerequisites:
      concepts: ["prime-number', "complex-analysis"]
      
    year_proved: 1896
    provers: ['hadamard", "de-la-vallee-poussin']
    independent_discovery: true
    
  # ===== Mathlib对齐 =====
  mathlib:
    path: "Mathlib.NumberTheory.PrimeCountingEstimate"
    main_theorem: 'prime_counting_estimate"
    coverage: "partial"
