{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../FormalMath-Interactive/src/*"],
      "@components/*": ["../FormalMath-Interactive/src/components/*"],
      "@hooks/*": ["../FormalMath-Interactive/src/hooks/*"],
      "@utils/*": ["../FormalMath-Interactive/src/utils/*"]
    },
    "types": ["jest", "@testing-library/jest-dom", "node", "cypress"]
  },
  "include": [
    "unit/**/*",
    "e2e/**/*",
    "../FormalMath-Interactive/src/**/*"
  ],
  "exclude": ["node_modules"]
}
