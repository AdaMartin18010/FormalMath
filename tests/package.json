{
  "name": "formalmath-tests",
  "version": "1.0.0",
  "description": "FormalMath 自动化测试套件",
  "private": true,
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --config=frontend/jest.config.js --coverage",
    "test:unit:watch": "jest --config=frontend/jest.config.js --watch",
    "test:e2e": "cypress run --config-file frontend/cypress.config.ts",
    "test:e2e:open": "cypress open --config-file frontend/cypress.config.ts",
    "test:python": "pytest backend/ -v --cov=../tools --cov-report=html --cov-report=term",
    "test:python:unit": "pytest backend/unit -v",
    "test:python:integration": "pytest backend/integration -v",
    "test:lean4": "lake test",
    "test:ci": "npm run test:unit && npm run test:python:unit && npm run test:e2e",
    "coverage:merge": "npx nyc merge coverage .nyc_output/out.json",
    "coverage:report": "npx nyc report --reporter=html --reporter=text-summary"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "cypress": "^13.6.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-sonar-reporter": "^2.0.0",
    "msw": "^2.0.11",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
