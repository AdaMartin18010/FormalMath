{
  "name": "formalmath-interactive",
  "version": "1.0.0",
  "description": "FormalMath交互式可视化界面框架 - React + D3.js + Mermaid.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "tsc && vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "jest --config=../tests/frontend/jest.config.js",
    "test:watch": "jest --config=../tests/frontend/jest.config.js --watch",
    "test:coverage": "jest --config=../tests/frontend/jest.config.js --coverage",
    "test:e2e": "cypress run --config-file ../tests/frontend/cypress.config.ts",
    "test:e2e:open": "cypress open --config-file ../tests/frontend/cypress.config.ts",
    "perf:test": "node scripts/performance-test.cjs",
    "perf:lighthouse": "node scripts/lighthouse-audit.cjs",
    "perf:audit": "npm run build && npm run preview & sleep 5 && npm run perf:lighthouse && taskkill /F /IM node.exe 2>nul",
    "perf:check": "node scripts/optimize-check.cjs",
    "bundle:analyze": "npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/three": "^0.183.1",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "d3": "^7.8.5",
    "d3-force-3d": "^3.0.6",
    "katex": "^0.16.9",
    "lib0": "^0.2.88",
    "lucide-react": "^0.294.0",
    "mermaid": "^10.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^9.0.1",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.20.1",
    "react-syntax-highlighter": "^15.5.0",
    "rehype-katex": "^7.0.0",
    "remark-math": "^6.0.0",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.1.0",
    "three": "^0.183.2",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.3",
    "yjs": "^13.6.11",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/d3": "^7.4.3",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cypress": "^13.6.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.0.11",
    "node": "^25.9.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "keywords": [
    "formalmath",
    "visualization",
    "d3",
    "mermaid",
    "react",
    "typescript",
    "knowledge-graph"
  ],
  "author": "FormalMath Team",
  "license": "MIT"
}
