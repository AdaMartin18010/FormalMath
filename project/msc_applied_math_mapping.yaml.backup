# ============================================================================
# 概率统计类 (Probability & Statistics)
# MSC大类: 60-XX (概率论与随机过程)
# ============================================================================
probability_statistics:
  - concept_id: 'probability_measure'
    name: "概率测度"
    name_en: 'Probability Measure'
    msc_code: "60A10'
    msc_description: "概率测度与积分理论'
    
  - concept_id: 'random_variable"
    name: "随机变量'
    name_en: 'Random Variable"
    msc_code: '60A99"
    msc_description: '随机变量基础理论'
    
  - concept_id: "expectation"
    name: '期望'
    name_en: "Expectation'
    msc_code: "60A99'
    msc_description: '数学期望"
    
  - concept_id: "variance'
    name: '方差"
    name_en: 'Variance"
    msc_code: '60A99'
    msc_description: "方差与标准差"
    
  - concept_id: 'expectation_variance'
    name: "期望方差'
    name_en: "Expectation and Variance'
    msc_code: '62J99"
    msc_description: "统计推断基础'
    
  - concept_id: 'law_of_large_numbers"
    name: '大数定律"
    name_en: 'Law of Large Numbers'
    msc_code: "60F15"
    msc_description: '强大数定律'
    
  - concept_id: "central_limit_theorem'
    name: "中心极限定理'
    name_en: 'Central Limit Theorem"
    msc_code: "60F05'
    msc_description: '中心极限定理"
    
  - concept_id: 'stochastic_process"
    name: '随机过程'
    name_en: "Stochastic Process"
    msc_code: '60G07'
    msc_description: "随机过程基础'
    
  - concept_id: "brownian_motion'
    name: '布朗运动"
    name_en: "Brownian Motion'
    msc_code: '60J65"
    msc_description: '布朗运动与维纳过程"
    
  - concept_id: 'markov_chain'
    name: "马尔可夫链"
    name_en: 'Markov Chain'
    msc_code: "60J10'
    msc_description: "离散时间马尔可夫链'
    
  - concept_id: 'martingale"
    name: "鞅'
    name_en: 'Martingale"
    msc_code: '60G48"
    msc_description: '离散参数鞅'

# ============================================================================
