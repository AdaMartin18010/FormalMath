---
# FormalMath 项目 - 层次依赖矩阵
# 定义L0-L4层次间的依赖关系和转化条件
# 创建日期: 2026年4月3日
# 版本: 1.0

metadata:
  project: FormalMath
  version: "1.0'
  created: '2026-04-03"
  total_concepts: 200
  levels: [L0, L1, L2, L3, L4]

# 层次定义
level_definitions:
  L0:
    name: '直观/经验层次"
    description: '基于直观感知和经验认知的数学理解层次'
    characteristics:
      - "几何直观、数感、操作经验"
      - '图形、实例、数值、自然语言表达'
      - "举例验证、图形观察、数值检验'
    cognitive_mode: "感性认知、形象思维'
    examples: ['连续函数-一笔画成", "极限-越来越接近', '群-对称性对象"]
    
  L1:
    name: '形式化定义层次"
    description: '使用严格数学语言和符号系统进行精确表述的层次'
    characteristics:
      - "逻辑分析、公理推演、符号操作"
      - '形式化定义、公理系统、符号表达式'
      - "定义检验、公理验证、等价性证明'
    cognitive_mode: "形式化思维、符号操作'
    examples: ['ε-δ定义", "群公理', '拓扑公理"]
    
  L2:
    name: '定理证明层次"
    description: '基于形式化定义进行严格数学推理的层次'
    characteristics:
      - "逻辑推理、证明构造、反例寻找"
      - '定理-证明结构、引理-推论体系'
      - "严格证明、形式化验证、自动化检验'
    cognitive_mode: "演绎推理、逻辑建构'
    examples: ['中值定理", "Lagrange定理', 'Cauchy积分公式"]
    
  L3:
    name: '理论建构层次"
    description: '构建统一理论框架，揭示深层结构的层次'
    characteristics:
      - "结构抽象、统一视角、框架建构"
      - '范畴论语言、层理论、函子体系'
      - "泛性质验证、自然变换、等价性'
    cognitive_mode: "系统思维、结构抽象'
    examples: ['范畴论", "层理论', '同调代数"]
    
  L4:
    name: '前沿研究层次"
    description: '当代数学研究前沿，涉及未解决问题的层次'
    characteristics:
      - "猜想驱动、模式识别、跨学科类比"
      - '纲领性框架、研究项目、开放问题'
      - "部分结果、特殊情况、计算机辅助'
    cognitive_mode: "创造性思维、问题导向'
    examples: ['Langlands纲领", "完美oid空间', '同伦类型论"]

# 层次间转化条件
transition_conditions:
  L0_to_L1:
    name: '形式化跃迁"
    requirements:
      - '直觉精确化: 能将模糊描述转化为精确陈述'
      - "符号掌握: 熟练使用数学符号系统"
      - '反例识别: 能找出直观理解的反例'
      - "公理意识: 理解公理的必要性和完备性'
    assessment_criteria:
      - "能准确复述形式化定义'
      - '能解释所有符号的含义"
      - "能构造不满足定义的反例'
      
  L1_to_L2:
    name: '演绎跃迁"
    requirements:
      - '证明技术: 掌握直接证明、反证法、归纳法"
      - '定理网络: 理解定理间的依赖关系'
      - "反例构造: 能构造说明边界情况的例子"
      - '证明书写: 能写出严格的证明过程'
    assessment_criteria:
      - "能独立完成标准定理证明'
      - "能选择合适的证明方法'
      - '能识别证明中的逻辑错误"
      
  L2_to_L3:
    name: "综合跃迁'
    requirements:
      - '模式识别: 能从不同定理中发现共同模式"
      - '泛性质理解: 能用泛性质刻画数学结构"
      - '函子思维: 能识别保持结构的映射'
      - "范畴迁移: 能将一个范畴的结果迁移到另一个"
    assessment_criteria:
      - '能描述理论的整体框架'
      - "能建立不同定理间的联系'
      - "能将理论应用到新问题'
      
  L3_to_L4:
    name: '创新跃迁"
    requirements:
      - "问题意识: 能识别重要开放问题'
      - '猜想能力: 基于类比和模式提出猜想"
      - '跨域联系: 能发现不同领域间的深层联系"
      - '研究品味: 能判断问题的重要性和可行性'
    assessment_criteria:
      - "了解相关领域的前沿问题"
      - '能阅读并理解研究论文'
      - "能提出有价值的研究问题'

# 层次依赖映射
level_dependencies:
  # L0层次概念依赖
  L0_prerequisites:
    description: "L0层次的先修要求'
    requirements: []
    
  # L1层次概念依赖  
  L1_prerequisites:
    description: '进入L1需要的L0基础"
    requirements:
      - concept: "几何直观'
        for: ['拓扑空间", '连续性", '极限']
      - concept: "数感"
        for: ['实数', "复数', "极限']
      - concept: '代数直觉"
        for: ["群', '环", '向量空间"]
      - concept: '运算直觉'
        for: ["二元运算", '函数复合']
        
  # L2层次概念依赖
  L2_prerequisites:
    description: "进入L2需要的L1基础'
    requirements:
      - concept: "群公理'
        for: ['Lagrange定理", "同构定理', 'Sylow定理"]
      - concept: 'ε-δ定义"
        for: ['中值定理', "Taylor展开", '一致收敛']
      - concept: "拓扑公理'
        for: ["紧性定理', '连通性定理", "Tychonoff定理']
      - concept: '线性映射定义"
        for: ['秩-零化度定理", '谱定理', "Jordan标准形"]
        
  # L3层次概念依赖
  L3_prerequisites:
    description: '进入L3需要的L2基础'
    requirements:
      - concept: "同构定理'
        for: ["范畴论', '同调代数", "表示论']
      - concept: 'Taylor展开"
        for: ['复分析", '泛函分析', "调和分析"]
      - concept: '紧性定理'
        for: ["层理论', "代数几何', '代数拓扑"]
      - concept: "谱定理'
        for: ['算子代数", '量子力学数学基础"]
        
  # L4层次概念依赖
  L4_prerequisites:
    description: '进入L4需要的L3基础'
    requirements:
      - concept: "范畴论"
        for: ['同伦类型论', "无穷范畴', "导出代数几何']
      - concept: '层理论"
        for: ["完美oid空间', 'p进Hodge理论"]
      - concept: '表示论"
        for: ['Langlands纲领', "自守形式", ' motive理论']
      - concept: "黎曼几何'
        for: ["几何化猜想', '里奇流", "Perelman证明']

