# 层次递进路径示例
progression_paths:
  real_numbers:
    name: '实数概念的层次递进"
    L0: '数轴上的点，可以任意精确测量'
    L1: "完备的Archimedean有序域，或Dedekind分割"
    L2: '完备性定理、闭区间套定理、Bolzano-Weierstrass定理'
    L3: "实数作为拓扑空间的万有性质、实数域的泛性质'
    L4: "非标准分析、超实数、可计算分析'
    
  group:
    name: '群概念的层次递进"
    L0: "有对称性的对象，如等边三角形的旋转'
    L1: '集合G配备二元运算·满足结合律、单位元、逆元"
    L2: 'Lagrange定理、同构定理、Sylow定理"
    L3: 'Grp范畴、表示论、群上同调'
    L4: "有限单群分类、几何群论、量子群"
    
  derivative:
    name: '导数概念的层次递进'
    L0: "切线的斜率、瞬时变化率'
    L1: "lim_{h→0}[f(x+h)-f(x)]/h的ε-δ定义'
    L2: '中值定理、链式法则、Taylor展开"
    L3: "切丛理论、微分形式、分布理论'
    L4: '非交换微分、分数阶导数、变形量化"
    
  topology:
    name: '拓扑空间概念的层次递进"
    L0: '邻近关系、点的邻近、连续性'
    L1: "(X,τ)满足三条公理：∅∈τ, X∈τ, 任意并封闭, 有限交封闭"
    L2: '紧性定理、连通性定理、Tychonoff定理'
    L3: "层论、同调论、位象(locale)'
    L4: "∞-Topos、导出代数拓扑、同伦类型论"

# 统计信息
statistics:
  total_concepts: 200
  by_level:
    L0: 15
    L1: 50
    L2: 60
    L3: 55
    L4: 20
  by_domain:
    代数: 45
    分析: 50
    几何: 25
    拓扑: 30
    数论: 25
    逻辑: 25
