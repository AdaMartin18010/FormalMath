        },
        {
          "name": "Coding Theory",
          "chinese_name": "编码理论",
          "reference": "WP-DM-004"
        }
      ],
      "key_theorems": [
        {
          "name": "Binomial Theorem",
          "formula": "(x+y)^n = Σ(k=0 to n) C(n,k) x^k y^(n-k)"
        },
        {
          "name": "Vandermonde's Identity",
          "formula": "Σ(k=0 to r) C(m,k)C(n,r-k) = C(m+n,r)"
        }
