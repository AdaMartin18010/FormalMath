            },
            {
              "name": "Permutations",
              "chinese_name": "排列",
              "formula": "P(n,r) = n!/(n-r)!"
            },
            {
              "name": "Combinations",
              "chinese_name": "组合",
              "formula": "C(n,r) = n!/(r!(n-r)!)"
            },
            {
              "name": "Binomial Coefficients",
              "chinese_name": "二项式系数",
              "key_identities": [
                "Symmetry: C(n,k) = C(n,n-k)",
                "Pascal's Identity: C(n,k) = C(n-1,k-1) + C(n-1,k)",
                "Binomial Theorem: (x+y)^n = Σ C(n,k)x^k y^(n-k)"
              ]
            },
            {
              "name": "Generating Functions",
              "chinese_name": "生成函数"
            }
          ]
        },
        {
          "name": "Extremal Combinatorics",
          "chinese_name": "极值组合学"
        },
        {
