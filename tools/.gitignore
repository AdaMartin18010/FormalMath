# =============================================================================
# FormalMath Tools 目录 .gitignore
# Python工具特定配置
# =============================================================================

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
env/
ENV/
.venv/

# 分发/打包
*.egg-info/
dist/
build/

# 测试和覆盖率
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# IDE
.vscode/
.idea/
*.swp

# 日志
*.log
logs/

# 环境变量
.env
.env.local

# 临时文件
*.tmp
tmp/

# 本地数据文件
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5

# 模型文件（如果过大）
*.pt
*.pth
*.onnx
*.pb
models/*.bin
models/*.safetensors
