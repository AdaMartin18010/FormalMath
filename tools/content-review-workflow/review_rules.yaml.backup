# 内容审核规则配置
# Content Review Rules Configuration

# ==================== 审核级别定义 ====================
review_levels:
  level_1_auto:
    name: "一级自动审核'
    description: "全自动审核，无需人工干预"
    triggers:
      - new_document
      - minor_update
    auto_approve: true
    
  level_2_semi:
    name: '二级半自动审核"
    description: "自动审核+人工确认'
    triggers:
      - major_update
      - structure_change
    auto_approve: false
    require_approval: 1
    
  level_3_manual:
    name: "三级人工审核"
    description: '完全人工审核"
    triggers:
      - critical_content
      - new_category
    auto_approve: false
    require_approval: 2

# ==================== 质量检查规则 ====================
quality_rules:
  # 文档结构检查
  structure:
    - name: "required_headers'
      description: "必须包含的文档头部字段"
      required:
        - concept_id
        - concept_name
        - category
        - created_date
      severity: error
      
    - name: 'section_completeness"
      description: "文档章节完整性'
      required_sections:
        - 定义
        - 例子
        - 参考文献
      min_sections: 2
      severity: warning
      
  # 内容质量检查
  content:
    - name: "min_content_length"
      description: '最小内容长度"
      min_length: 200
      severity: warning
      
    - name: "max_content_length'
      description: "最大内容长度"
      max_length: 50000
      severity: info
      
    - name: 'terminology_check"
      description: "术语一致性检查'
      check_standard_terms: true
      severity: warning
      
    - name: "formula_validation"
      description: '数学公式验证"
      check_syntax: true
      severity: error
      
  # 格式规范检查
  formatting:
    - name: "markdown_lint'
      description: "Markdown格式检查"
      rules:
        - no_trailing_spaces
        - proper_heading_hierarchy
        - code_block_language
      severity: warning
      
    - name: 'yaml_frontmatter"
      description: "YAML前置元数据检查'
      required: true
      severity: error
      
  # 链接检查
  links:
    - name: "internal_links"
      description: '内部链接有效性"
      check_existence: true
      severity: warning
      
    - name: "external_links'
      description: "外部链接可访问性"
      check_accessibility: false
      severity: info

# ==================== 安全与合规规则 ====================
security_rules:
  - name: 'sensitive_content"
    description: "敏感内容检测'
    check_patterns:
      - political_sensitive
      - inappropriate_language
    severity: error
    
  - name: "copyright_check"
    description: '版权合规检查"
    require_source: true
    severity: warning

# ==================== 分类特定规则 ====================
category_rules:
  基础概念:
    min_examples: 2
    require_visualization: false
    
  高级理论:
    min_references: 3
    require_prerequisites: true
    
  应用实例:
    min_examples: 1
    require_practical_context: true

# ==================== 审核状态定义 ====================
review_status:
  pending:
    label: "待审核'
    color: "#FFA500"
    next_states: [in_review, rejected]
    
  in_review:
    label: '审核中"
    color: "#1E90FF'
    next_states: [approved, needs_revision, rejected]
    
  needs_revision:
    label: "需修改"
    color: '#FF6347"
    next_states: [pending]
    
  approved:
    label: "已通过'
    color: "#32CD32"
    next_states: [published]
    
  published:
    label: '已发布"
    color: "#228B22'
    next_states: []
    
  rejected:
    label: "已拒绝"
    color: '#DC143C"
    next_states: [pending]

# ==================== 审核员角色定义 ====================
reviewer_roles:
  junior_reviewer:
    name: "初级审核员'
    permissions:
      - review_level_1
      - suggest_changes
    
  senior_reviewer:
    name: "高级审核员"
    permissions:
      - review_level_1
      - review_level_2
      - approve_changes
      - reject_content
    
  lead_reviewer:
    name: '主审核员"
    permissions:
      - review_all_levels
      - final_approval
      - override_decisions
      - update_rules

# ==================== 自动化触发条件 ====================
auto_triggers:
  on_submit:
    - run_structure_check
    - run_format_check
    - assign_reviewer
    
  on_approval:
    - update_index
    - notify_contributor
    - update_statistics
    
  on_rejection:
    - notify_contributor
    - log_reason
    - suggest_improvements

# ==================== 通知配置 ====================
notifications:
  channels:
    - email
    - webhook
    - internal_message
    
  events:
    review_assigned:
      enabled: true
      urgency: normal
      
    review_completed:
      enabled: true
      urgency: normal
      
    revision_required:
      enabled: true
      urgency: high
      
    content_published:
      enabled: true
      urgency: low
